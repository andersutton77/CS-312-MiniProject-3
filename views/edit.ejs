<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <section class="create-post"><h1>Edit Blog Post</h1>

<form
    action="/edit/<%= post.id %>"
    method="POST">

    <input
        
    type="text"
        name="author"
        value="<%= post.author %>"
        required>

    <input
       
    type="text"
        name="title"
        value="<%= post.title %>"
        required>

    <textarea
        
    name="content"
        rows="6"
        required><%= post.content %></textarea>

    <button type="submit">
       
        Save Changes

    </button>

</form>

<!-- exit button -->
<a href="/">
    Back to Homepage
</a>

</body>
</html>